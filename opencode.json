{
  "$schema": "https://opencode.ai/config.json",

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "docs/public/**",
      "docs/generated/**",
      "docs/.vitepress/cache/**",
      "docs/.vitepress/dist/**"
    ]
  }
}
